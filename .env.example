# Browser-safe Supabase values only.
# Never expose a Supabase service role key with NEXT_PUBLIC_.
# Server-only secrets, if added later, must stay out of client components.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public app URL used for Stripe Checkout success/cancel redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only Stripe key. Never prefix this with NEXT_PUBLIC_.
# Payments must use Stripe Checkout or Stripe Customer Portal only.
STRIPE_SECRET_KEY=
